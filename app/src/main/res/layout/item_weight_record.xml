<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="16dp">

    <!-- 日期行 -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        tools:text="2026年06月12日 五" />

    <!-- 体重 + 变化量行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="12dp"
        android:orientation="horizontal">

        <!-- 早晨体重 -->
        <LinearLayout
            android:id="@+id/layoutMorning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- 早 图标 -->
            <TextView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:text="早"
                android:textSize="9sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_morning_tag" />

            <TextView
                android:id="@+id/tvMorningWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                tools:text="108.5斤" />

        </LinearLayout>

        <!-- 晚间体重 -->
        <LinearLayout
            android:id="@+id/layoutEvening"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:visibility="gone">

            <!-- 晚 图标 -->
            <TextView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:gravity="center"
                android:text="晚"
                android:textSize="9sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_evening_tag" />

            <TextView
                android:id="@+id/tvEveningWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="17sp"
                android:textColor="@color/text_primary"
                tools:text="110.4斤" />

        </LinearLayout>

        <!-- 弹簧 -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 变化量 -->
        <TextView
            android:id="@+id/tvChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:visibility="invisible"
            tools:text="+ 0.6斤" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider" />

</LinearLayout>
